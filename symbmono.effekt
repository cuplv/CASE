                do binopI(st, LtOp(), v1, v2)
            case GtOp() =>
                val (v1, _) = resume((E(e1), st))
                val (v2, _) = resume((E(e2), st))
                do binopI(st, GtOp(), v1, v2)
            case LeOp() =>
                val (v1, _) = resume((E(e1), st))
                val (v2, _) = resume((E(e2), st))
                do binopI(st, LeOp(), v1, v2)
            case GeOp() =>
                val (v1, _) = resume((E(e1), st))
                val (v2, _) = resume((E(e2), st))
                do binopI(st, GeOp(), v1, v2)
        }
    }
    with unopE[SymStore, Prog] { (st, op, e) =>
        op match {
            case NotOp() => (SymCst(Not(e)), st)
        }
    }
    with asgnE[SymStore, Prog] { (st, x, v) =>
        do asgnI(st, x, SymCst(v))
    }
    with ifE[SymStore, Prog] { (st, g, t, f) =>
        val (gv, _) = resume((E(g), st))
        val (fv, fs) = resume((S(f), st))
        val (tv, ts) = resume((S(t), st))
        (SymCst(Cst(U())), AND(IMP(gv, ts), IMP(NOT(gv), fs)))
    }
    with whileE[SymStore, Prog] { (st, g, b) =>
        val modified:Set[String] = findModified(b, set::emptyGeneric())
        val marked = markStore(st, modified)
        (SymCst(Cst(U())), marked)
    }
    with seqE[SymStore, Prog] { (st, s1, s2) =>
        val (_, st1) = resume((S(s2), st))
        val (v2, st2) = resume((S(s1), st1))
        (v2, st2)
    }
    with skipE[SymStore, SymStore] { (st) =>
        (SymCst(Cst(U())), st)
    }
}

def run(prog:Prog, init: SymStore) : (SymStore, SymStore) = {
        try {
            with symbolicElim()
            eval((prog, init))
        }
        with cstI[SymStore, SymStore] {(st, v) =>
