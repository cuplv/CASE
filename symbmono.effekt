    with cstE[SymStore, SymStore] { (st, v) =>
        do cstI(st, v)
    }
    with varE[SymStore, Prog] { (st, x) =>
        do varI(st, x)
    }
    with binopE[SymStore, Prog] { (st, op, e1, e2) =>
