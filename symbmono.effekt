        }
}
*/

def eval_sym(e: Prog, st: SymStore): (SymStore, SymStore) = {
  e match {
    case E(e) => e match {
      case Cst(v) => (SymCst(Cst(v)), st)
      case Var(x) => (SymVar(x), st)
      case Plus(e1, e2) => (SymCst(Plus(e1, e2)), st)
      case Minus(e1, e2) => (SymCst(Minus(e1, e2)), st)
      case Eq(e1, e2) =>
        val (v1, st1) = eval_sym(E(e1), st)
        val (v2, st2) = eval_sym(E(e2), st1)
        (v1, v2) match {
          case (SymCst(Cst(I(i1))), SymCst(Cst(I(i2)))) => (SymCst(Cst(B(i1 == i2))), st2)
          case (SymCst(Cst(B(b1))), SymCst(Cst(B(b2)))) => (SymCst(Cst(B(b1 == b2))), st2)
          case (SymCst(Cst(Str(s1))), SymCst(Cst(Str(s2)))) => (SymCst(Cst(B(s1 == s2))), st2)
          case _ => (EQ(v1, v2), st2)
        }
      case Lt(e1, e2) =>
        val (v1, st1) = eval_sym(E(e1), st)
        val (v2, st2) = eval_sym(E(e2), st1)
        (v1, v2) match {
          case (SymCst(Cst(I(i1))), SymCst(Cst(I(i2)))) => (SymCst(Cst(B(i1 < i2))), st2)
          case _ => (LT(v1, v2), st2)
        }
      case Gt(e1, e2) =>
        val (v1, st1) = eval_sym(E(e1), st)
        val (v2, st2) = eval_sym(E(e2), st1)
        (v1, v2) match {
          case (SymCst(Cst(I(i1))), SymCst(Cst(I(i2)))) => (SymCst(Cst(B(i1 > i2))), st2)
          case _ => (GT(v1, v2), st2)
        }
      case Le(e1, e2) =>
        val (v1, st1) = eval_sym(E(e1), st)
        val (v2, st2) = eval_sym(E(e2), st1)
        (v1, v2) match {
          case (SymCst(Cst(I(i1))), SymCst(Cst(I(i2)))) => (SymCst(Cst(B(i1 <= i2))), st2)
          case _ => (LE(v1, v2), st2)
        }
      case Ge(e1, e2) =>
        val (v1, st1) = eval_sym(E(e1), st)
        val (v2, st2) = eval_sym(E(e2), st1)
        (v1, v2) match {
          case (SymCst(Cst(I(i1))), SymCst(Cst(I(i2)))) => (SymCst(Cst(B(i1 >= i2))), st2)
          case _ => (GE(v1, v2), st2)
        }
      case Not(e) =>
        val (v, st1) = eval_sym(E(e), st)
        (NOT(v), st1)
    }
    case S(stmt) => stmt match {
      case Asgn(x, e) =>
        val (v, st1) = eval_sym(E(e), st)
        v match {
          case SymCst(e) => (SymCst(Cst(U())), replace(st1, x, e))
          case _  => ((SymCst(Cst(U())), st1))
        }
      case If(g, t, f) =>
        val (gv, _) = eval_sym(E(g), st)
        val (fv, fs) = eval_sym(S(f), st)
        val (tv, ts) = eval_sym(S(t), st)
        (SymCst(Cst(U())), AND(IMP(gv, ts), IMP(NOT(gv), fs)))
      case While(g, b) =>
        val modified:Set[String] = findModified(b, set::emptyGeneric())
        val marked = markStore(st, modified)
        (SymCst(Cst(U())), marked)
      case Seq(s1, s2) =>
        val (_, st1) = eval_sym(S(s2), st)
        val (v2, st2) = eval_sym(S(s1), st1)
        (v2, st2)
      case Skip() => (SymCst(Cst(U())), st)
    }
  }
}

def main() = {
  with on[WrongFormat].panic
  with on[IOError].panic
  val defaultInit: SymStore = EQ(SymVar("x"), SymCst(Cst(I(1))))

  // parse files to evaluate
  val file: List[String] = args::commandLineArgs()
  file match {
    case Cons(_, _) => {
      // for each file passed in
      file.foreach{ (f) =>
        // read json ast
        val jsonFile: String = filesystem::readFile(f)
        feed(jsonFile) {
          with scanner[Char]
          // decode into effekt
          val (_, jsonVal) = build { decodeJson() }
          // parse to Prog
          val parsed = pythonAstToProg(jsonVal)
          // evaluate
          val (v, s) = eval_sym(parsed, defaultInit)
          // extract end state
          
          // print output
          println("---------")
          printSym(s)
          println("---------")
        }
      }
    }
    case Nil() => println("no file passed in")
  }
}