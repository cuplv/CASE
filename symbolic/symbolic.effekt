                case (SymCst(Cst(Str(s1))), SymCst(Cst(Str(s2)))) => resume((SymCst(Cst(B(s1 == s2))), st))
                case _ => resume((EQ(d1, d2), st))
            }
        }
}

def symbolicLtI {prog: => (SymStore, SymStore)/ltI[SymStore, SymStore]}: (SymStore, SymStore) = {
    try prog()
    with ltI[SymStore, SymStore] {(st, d1, d2) =>
