def symbolicAsgnI {prog: => (SymStore, SymStore)/asgnI[SymStore, SymStore]}: (SymStore, SymStore) = {
    try prog()
    with asgnI[SymStore, SymStore] {(st, x, v) =>
        // println("Entered asgnI for " ++ x)
