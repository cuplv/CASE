        }
}
*/
def run(prog:Prog, init: SymStore) : (SymStore, SymStore) = {
        try {
            with symbolicElim()
            eval((prog, init))
        }
        with cstI[SymStore, SymStore] {(st, v) =>
            resume((SymCst(Cst(v)), st))
        }
        with varI[SymStore, SymStore] {(st, x) =>
        //   println("Entered varI for: " ++ x)
            resume((SymVar(x), st))
        }
        with asgnI[SymStore, SymStore] {(st, x, v) =>
            // println("Entered asgnI for " ++ x)
            v match {
                case SymCst(v) => resume((SymCst(Cst(U())), replace(st, x, v)))
                case _  => resume((SymCst(Cst(U())), st))
            }        
        }
        with eqI[SymStore, SymStore] {(st, d1, d2) =>
          resume((EQ(d1, d2), st))
        } 
        with ltI[SymStore, SymStore] {(st, d1, d2) =>
          resume((LT(d1, d2), st))
        }
        with gtI[SymStore, SymStore] {(st, d1, d2) =>
            resume((GT(d1, d2), st))
        }
        with leI[SymStore, SymStore] {(st, d1, d2) =>
            resume((LE(d1, d2), st))
        }
        with geI[SymStore, SymStore] {(st, d1, d2) =>
            resume((GE(d1, d2), st))
        }
}

def main() = {
  with on[WrongFormat].panic
  with on[IOError].panic
  val defaultInit: SymStore = EQ(SymVar("x"), SymCst(Cst(I(1))))

  // parse files to evaluate
  val file: List[String] = args::commandLineArgs()
  file match {
    case Cons(_, _) => {
      // for each file passed in
      file.foreach{ (f) =>
        // read json ast
        val jsonFile: String = filesystem::readFile(f)
        feed(jsonFile) {
          with scanner[Char]
          // decode into effekt
          val (_, jsonVal) = build { decodeJson() }
          // parse to Prog
          val parsed = pythonAstToProg(jsonVal)
          // evaluate
          val (v, s) = run(parsed, defaultInit)
          // extract end state
          
          // print output
          println("---------")
          printSym(s)
        //   printSym(v)
          println("---------")
        }
      }
    }
    case Nil() => println("no file passed in")
  }
}