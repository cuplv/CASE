                case (SymCst(Cst(I(i1))), SymCst(Cst(I(i2)))) => resume((SymCst(Cst(B(i1 < i2))), st))
                case _ => resume((LT(d1, d2), st))
            }
        }
}

def symbolicGtI {prog: => (SymStore, SymStore)/gtI[SymStore, SymStore]}: (SymStore, SymStore) = {
