def symbolicEqI {prog: => (SymStore, SymStore)/eqI[SymStore, SymStore]}: (SymStore, SymStore) = {
    try prog()
    with eqI[SymStore, SymStore] {(st, d1, d2) =>
            (d1, d2) match {
