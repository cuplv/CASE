module typecheck

import pylang/interp
import pylang/pyconv
import pylang/syntax

import args
import io/error
import io/filesystem
import json
import map
import scanner

type Type {
  TInt()
  TBool()
  TStr()
  TUnit()
  TError()
}

def println(t: Type) = t match {
  case TInt() => println("TInt")
  case TBool() => println("TBool")
  case TStr() => println("TStr")
  case TUnit() => println("TUnit")
  case TError() => println("TError")
}

def println(ts: List[Type]) = {
  println("{")
  ts.foreach { t => println(t) }
  println("}")
}

def typeEquals(t1: Type, t2: Type): Bool = {
  (t1, t2) match {
    case (TInt(), TInt()) => true
    case (TBool(), TBool()) => true
    case (TStr(), TStr()) => true
    case (TUnit(), TUnit()) => true
    case (TError(), TError()) => true
    case _ => false
  }
}

def canCompare(t1: Type, t2: Type): Bool = {
  (t1, t2) match {
    case (TInt(), TInt()) => true
    case (TInt(), TBool()) => true
    case (TBool(), TInt()) => true
    case (TBool(), TBool()) => true
    case (TStr(), TStr()) => true
    case _ => false
  }
}

def dedupTypes(ts: List[Type]): List[Type] = {
  ts match {
    case Nil() => Nil()
    case Cons(t, rest) => {
      val deduped = dedupTypes(rest)
      if (deduped.any { existing => typeEquals(existing, t) }) {
        deduped
      } else {
        Cons(t, deduped)
      }
    }
  }
}

def addIfUnique(ts: List[Type], t: Type): List[Type] = {
  if (ts.any { existing => typeEquals(existing, t) }) {
    ts
  } else {
    ts.append([t])
  }
}

def mergeTypeLists(existing: List[Type], newTypes: List[Type]): List[Type] = {
  newTypes match {
    case Nil() => existing
    case Cons(t, rest) => mergeTypeLists(addIfUnique(existing, t), rest)
  }
}

def mergeStates(st1: State[List[Type]], st2: State[List[Type]]): State[List[Type]] = {
  val m1 = st1 match { case St(a) => a }
  val m2 = st2 match { case St(a) => a }
  var merged = m1
  map::foreach(m2) { (k, newTypes) =>
    val existing = map::get[String, List[Type]](merged, k) match {
      case Some(types) => types
      case None() => []
    }
    val updated = mergeTypeLists(existing, newTypes)
    merged = merged.put(k, updated)
  }
  St(merged)
}

def run(prog: Prog, init: State[List[Type]]): (List[Type], State[List[Type]]) = {
  try {
    with eval_forwards[List[Type]]
    eval((prog, init))
  }

  with cstI[List[Type], State[List[Type]]] {(st, v) => 
    val ts = v match {
      case I(_) => [TInt()]
      case B(_) => [TBool()]
      case Str(_) => [TStr()]
      case U() => [TUnit()]
    }
    resume((ts, st))
  }

  with varI[List[Type]] { (st, x) =>
    val m: Map[String, List[Type]] = st match {case St(a) => a}
    val ts = map::get[String, List[Type]](m, x) match {
      case Some(types) => types
      case None() => [TError()]
    }
    resume((ts, st))
  }

  with asgnI[List[Type]] { (st, x, ts) =>
    val m = st match {case St(a) => a}
    val newState = m.put(x, ts)
    resume(([TUnit()], St(newState)))
  }

  with plusI[List[Type]] { (st, ts1, ts2) =>
    val result = ts1.flatMap { t1 =>
      ts2.map { t2 =>
        (t1, t2) match {
          case (TInt(), TInt()) => TInt()
          case (TInt(), TBool()) => TInt()
          case (TBool(), TInt()) => TInt()
          case (TStr(), TStr()) => TStr()
          case _ => TError()
        }
      }
    }
    resume((dedupTypes(result), st))
  }

  with minusI[List[Type]] { (st, ts1, ts2) =>
    val result = ts1.flatMap { t1 =>
      ts2.map { t2 =>
        (t1, t2) match {
          case (TInt(), TInt()) => TInt()
          case (TInt(), TBool()) => TInt()
          case (TBool(), TInt()) => TInt()
          case _ => TError()
        }
      }
    }
    resume((dedupTypes(result), st))
  }

  with notI[List[Type]] { (st, ts) =>
    val result = ts.map { t =>
      t match {
        case TBool() => TBool()
        case _ => TError()
      }
    }
    resume((dedupTypes(result), st))
  }

  with eqI[List[Type]] {
    (st, ts1, ts2) => {
      val result = ts1.flatMap { t1 =>
        ts2.map { t2 =>
          (t1, t2) match {
            case (TInt(), TInt()) => TBool()
            case (TBool(), TBool()) => TBool()
            case (TStr(), TStr()) => TBool()
            case _ => TError()
          }
        }
      }
      resume((dedupTypes(result), st))
    }
  }

  with ltI[List[Type]] {
    (st, ts1, ts2) => {
      val result = ts1.flatMap { t1 =>
        ts2.map { t2 =>
          if (canCompare(t1, t2)) TBool() else TError()
        }
      }
      resume((dedupTypes(result), st))
    }
  }
  with gtI[List[Type]] {
    (st, ts1, ts2) => {
      val result = ts1.flatMap { t1 =>
        ts2.map { t2 =>
          if (canCompare(t1, t2)) TBool() else TError()
        }
      }
      resume((dedupTypes(result), st))
    }
  }
  with leI[List[Type]] {
    (st, ts1, ts2) => {
      val result = ts1.flatMap { t1 =>
        ts2.map { t2 =>
          if (canCompare(t1, t2)) TBool() else TError()
        }
      }
      resume((dedupTypes(result), st))
    }
  }
  with geI[List[Type]] {
    (st, ts1, ts2) => {
      val result = ts1.flatMap { t1 =>
        ts2.map { t2 =>
          if (canCompare(t1, t2)) TBool() else TError()
        }
      }
      resume((dedupTypes(result), st))
    }
  }

  with ifI[List[Type]] {(stT, stF, ts, tsT, tsF) =>
    val result = dedupTypes(tsT.append(tsF))
    val merged = mergeStates(stT, stF)
    resume((result, merged))
  }

  with whileI[List[Type]] {(stG, stB, ts, tsB) =>
    val merged = mergeStates(stG, stB)
    resume(([TUnit()], merged))
  }

  with recurse[List[Type]] {(ts) =>
    val shouldRecurse = ts.any { t => t match {
      case TBool() => true
      case _ => false
    }}
    resume(shouldRecurse)
  }

  with seqI[List[Type]] {(_, st2, _, ts2) => resume((ts2, st2))}

  with skipI[List[Type]] {(st) => resume(([TUnit()], st))}
}

def main() = {
  with on[WrongFormat].panic
  with on[IOError].panic
  val init: Map[String, List[Type]] = map::empty(box compareStringBytes)

  // parse files to evaluate
  val file: List[String] = args::commandLineArgs()
  file match {
    case Cons(_, _) => {
      // for each file passed in
      file.foreach{ (f) =>
        // read json ast
        val jsonFile: String = filesystem::readFile(f)
        feed(jsonFile) {
          with scanner[Char]
          // decode into effekt
          val (_, jsonVal) = build { decodeJson() }
          // parse to Prog
          val parsed = pythonAstToProg(jsonVal)
          // evaluate
          val (_, s) = run(parsed, St(init))
          // extract end state
          val m = s match {case St(a) => a}
          // print output
          println("---------")
          m.foreach { (k,v) => println(k); println(v)}
          println("---------")
        }
      }
    }
    case Nil() => println("no file passed in")
  }
}